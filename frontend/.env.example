# FaceLipa - All Environment Variables
# =====================================
# Copy to .env (frontend) or set as Supabase secrets (Edge Functions)

# --- FRONTEND (Vercel / local dev) ---
# Required for Supabase client
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- SUPABASE EDGE FUNCTIONS (set via: supabase secrets set KEY=value) ---
# Auto-injected by Supabase (do not set manually):
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY

# Payment - Snippe (STK push)
SNIPPE_API_KEY=

# Payment - Tembo (MOMO collection + Create Wallet)
TEMBO_ACCOUNT_ID=
TEMBO_SECRET_KEY=
TEMBO_SANDBOX=true
TEMBO_HASH_KEY=

# Payment provider preference (snippe | tembo)
PAYMENT_PROVIDER=snippe

# Webhooks
WEBHOOK_BASE_URL=https://your-project.supabase.co/functions/v1

# SMS - Briq (optional)
BRIQ_API_KEY=

# Optional
USD_TO_TZS_RATE=2600
